# Copy to .env and fill in. Never commit .env.

# --- LLM backend ---
# Options: "ollama" | "anthropic" | "openai"
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2:3b

# Required if LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# Required if LLM_PROVIDER=openai
OPENAI_API_KEY=

# --- Ollama (local) ---
OLLAMA_HOST=http://localhost:11434

# --- Storage ---
DATA_DIR=./data
INDEX_DIR=./data/index

# --- Telemetry (optional) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
